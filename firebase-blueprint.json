{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile containing anagrafica details.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "companyName": { "type": "string" },
        "profileType": { "type": "string", "enum": ["hotel", "dest"] },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "formData": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "companyName", "profileType", "role", "createdAt"]
    },
    "AuditResult": {
      "title": "AuditResult",
      "description": "The result of an ESG audit.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "profileType": { "type": "string", "enum": ["hotel", "dest"] },
        "scores": {
          "type": "object",
          "properties": {
            "environment": { "type": "number" },
            "social": { "type": "number" },
            "governance": { "type": "number" }
          },
          "required": ["environment", "social", "governance"]
        },
        "totalScore": { "type": "number" },
        "answers": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "profileType", "scores", "totalScore", "answers", "createdAt"]
    },
    "UserJourney": {
      "title": "UserJourney",
      "description": "The certification journey for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["hotel", "dest"] },
        "currentMilestone": { "type": "number" },
        "statusList": { "type": "object" },
        "adminNotes": { "type": "string" },
        "sharedDocs": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "currentMilestone", "statusList", "createdAt", "updatedAt"]
    },
    "Milestone": {
      "title": "Milestone",
      "description": "A milestone in the certification journey.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "targetPillar": { "type": "string", "enum": ["E", "S", "G", "All"] },
        "requiredEvidence": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "label", "description", "targetPillar", "requiredEvidence", "order"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profiles."
    },
    "/audits/{auditId}": {
      "schema": { "$ref": "#/entities/AuditResult" },
      "description": "Stores completed ESG audits."
    },
    "/journeys/{journeyId}": {
      "schema": { "$ref": "#/entities/UserJourney" },
      "description": "Stores user certification journeys."
    },
    "/milestones/{milestoneId}": {
      "schema": { "$ref": "#/entities/Milestone" },
      "description": "Stores milestone definitions."
    }
  }
}
